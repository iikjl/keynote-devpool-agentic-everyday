# Authentication - pick ONE method:
#
# Method 1: GitHub Token (for automation/CI)
#   Must be a fine-grained PAT with "Copilot Requests" permission
#   Classic tokens (ghp_...) are silently ignored!
#   SDK also checks COPILOT_GITHUB_TOKEN and GH_TOKEN
GITHUB_TOKEN=
#
# Method 2: OAuth Device Flow (for interactive use)
#   Leave GITHUB_TOKEN empty - the SDK will prompt you to authenticate via browser
#
# Method 3: BYOK - Bring Your Own Key (no Copilot subscription needed)
#   Set provider-specific keys instead:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AZURE_OPENAI_API_KEY=

# (Optional) Copilot CLI Path - bundled with the SDK, usually auto-detected
COPILOT_CLI_PATH=copilot

# (Optional) Override default model (e.g., claude-sonnet-4, gpt-4o, gemini)
COPILOT_MODEL=

# (Optional) Default working directory for agent sessions
COPILOT_WORKING_DIR=
